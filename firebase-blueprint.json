{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user, can be a property owner or a guest.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["owner", "guest"] },
        "merchantProfile": {
          "type": "object",
          "properties": {
            "businessName": { "type": "string" },
            "logoUrl": { "type": "string" },
            "subdomain": { "type": "string" },
            "knowledgeBase": { "type": "string", "description": "Owner personal brand guidelines and property specific details." }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Property": {
      "title": "Property",
      "description": "A rental property listed on the platform.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "basePrice": { "type": "number" },
        "otaLinks": {
          "type": "object",
          "properties": {
            "airbnb": { "type": "string" },
            "vrbo": { "type": "string" }
          }
        },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "location": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "city": { "type": "string" },
            "country": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["active", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "basePrice", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A reservation for a property.",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" },
        "guestId": { "type": "string" },
        "guestEmail": { "type": "string", "format": "email" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "source": { "type": "string", "enum": ["direct", "airbnb", "vrbo"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "ownerId", "startDate", "endDate", "totalPrice", "status", "createdAt"]
    },
    "PricingCache": {
      "title": "PricingCache",
      "description": "Cached prices from external OTAs for comparison.",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "ota": { "type": "string", "enum": ["airbnb", "vrbo"] },
        "price": { "type": "number" },
        "lastFetched": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "ota", "price", "lastFetched"]
    },
    "SyncLog": {
      "title": "SyncLog",
      "description": "Logs of calendar synchronizations.",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failure"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "status", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "properties/{propertyId}": {
      "schema": "Property",
      "description": "Property listings."
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Property reservations."
    },
    "properties/{propertyId}/pricing_cache/{cacheId}": {
      "schema": "PricingCache",
      "description": "External OTA price data for a property."
    },
    "properties/{propertyId}/sync_logs/{logId}": {
      "schema": "SyncLog",
      "description": "Synchronization logs for a property."
    }
  }
}
